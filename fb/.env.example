# Facebook Page (Meta Graph API). The Page id + a long-lived Page access
# token. Mint both at once by running `bun run auth` after filling in the
# App ID/Secret rows below.
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

# Optional: Graph API version (default v21.0).
FACEBOOK_GRAPH_VERSION=

# Optional: publish single videos as Reels (3-phase upload). They get more
# reach than regular video posts. true | false. Default: true.
FACEBOOK_VIDEO_AS_REELS=

# Only needed for `bun run auth` (not at publish time).
# From developers.facebook.com → your app → Settings → Basic.
# Add http://localhost:4181/ to the app's "Facebook Login" Valid OAuth
# Redirect URIs.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Optional: change the localhost callback port if 4181 is busy.
FACEBOOK_AUTH_PORT=
