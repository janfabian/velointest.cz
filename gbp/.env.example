# Google Business Profile — local post publisher.
#
# IMPORTANT prerequisites (see README):
#  1. A Google Cloud project with the Business Profile APIs enabled.
#  2. Approved access to the Business Profile API (manual Google review,
#     can take days–weeks). Without it the API returns 403 even with a
#     valid token.

# OAuth client (Desktop app type) from Google Cloud Console → APIs &
# Services → Credentials. Needed only by `bun run auth`.
GBP_CLIENT_ID=
GBP_CLIENT_SECRET=

# Long-lived refresh token minted by `bun run auth`. Used at publish time
# to get a fresh access token on every run. Does not expire (unless revoked
# or unused for 6 months).
GBP_REFRESH_TOKEN=

# The account + location the posts go to. `bun run auth` discovers and writes
# these for you (it lists what you manage and lets you pick).
# Numeric ids, e.g. GBP_ACCOUNT_ID=123456789012345678901
GBP_ACCOUNT_ID=
GBP_LOCATION_ID=

# Optional: default language code for posts (default: cs).
GBP_LANG=

# Optional: change the localhost OAuth callback port (default 4182).
GBP_AUTH_PORT=
